# Locus Environment Variables Template
# Copy this file to .env and fill in your actual values

# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=your-openai-api-key-here

# Database Configuration (default for Docker setup)
DATABASE_URL=postgresql://locus_user:locus_password@postgres:5432/locus

# Redis Configuration
REDIS_URL=redis://redis:6379

# JWT Secrets (generate secure random strings for production)
JWT_SECRET=change-this-to-a-secure-random-string
JWT_REFRESH_SECRET=change-this-to-another-secure-random-string

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Coqui TTS Configuration
COQUI_TTS_HOST=coqui-tts
COQUI_TTS_PORT=8000
COQUI_TTS_PATH=http://coqui-tts:8000