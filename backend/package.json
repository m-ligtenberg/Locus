{
  "name": "locus-backend",
  "version": "5.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "migrate": "prisma migrate dev",
    "migrate:prod": "prisma migrate deploy",
    "generate": "prisma generate",
    "seed": "tsx src/scripts/seed.ts",
    "prepare": "npm run generate",
    "docker:build": "docker build -t locus-backend .",
    "validate": "tsc --noEmit && npm run lint && npm run test",
    "backup": "tsx src/jobs/backup.ts",
    "docs": "swagger-cli bundle openapi.yaml -o dist/openapi.json"
  },
  "dependencies": {
    "@opentelemetry/api": "1.7.0",
    "@prisma/client": "5.7.1",
    "axios": "1.6.2",
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "dd-trace": "4.20.0",
    "dotenv": "16.3.1",
    "express": "4.18.2",
    "fluent-ffmpeg": "2.1.2",
    "fs-extra": "11.2.0",
    "helmet": "7.1.0",
    "jsonwebtoken": "9.0.2",
    "morgan": "1.10.0",
    "multer": "1.4.4",
    "node-cron": "3.0.3",
    "openai": "4.20.1",
    "prisma": "5.7.1",
    "rate-limiter-flexible": "4.0.1",
    "redis": "4.6.11",
    "socket.io": "4.7.4",
    "swagger-ui-express": "5.0.0",
    "uuid": "9.0.1",
    "winston": "3.11.0",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "1.40.1",
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/fluent-ffmpeg": "2.1.24",
    "@types/fs-extra": "11.0.4",
    "@types/jsonwebtoken": "9.0.5",
    "@types/morgan": "1.9.9",
    "@types/multer": "1.4.11",
    "@types/node": "20.10.5",
    "@types/node-cron": "3.0.11",
    "@types/swagger-ui-express": "4.1.6",
    "@types/uuid": "9.0.7",
    "@typescript-eslint/eslint-plugin": "6.14.0",
    "@typescript-eslint/parser": "6.14.0",
    "eslint": "8.55.0",
    "tsx": "4.6.2",
    "typescript": "5.3.3",
    "vitest": "1.0.4"
  }
}